<%# locals: (icon:, message:, action_text: nil, action_path: nil) %>
<div class="empty-state text-center">
  <i data-lucide="<%= icon %>" class="empty-state-icon mb-2"></i>
  <p class="empty-state-message mb-3"><%= message %></p>
  <% if action_text.present? && action_path.present? %>
    <%= link_to action_text, action_path, class: "btn btn-primary" %>
  <% end %>
</div>
